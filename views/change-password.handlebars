<!DOCTYPE html>
<html lang="en" class="h-full">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
        <title>LABubuddies - Change Password</title>
        <link href="../CSS/login-style.css" rel="stylesheet">
        <script src="https://cdn.tailwindcss.com"></script>
        <style>
            /* Eye toggle button */
            .input-wrapper {
                position: relative;
                width: 16rem; /* w-64 */
            }
            .input-wrapper input {
                width: 100%;
                padding: 0.5rem 2.5rem 0.5rem 1rem;
                border-radius: 9999px;
                outline: none;
                box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
            }
            .toggle-eye {
                position: absolute;
                right: 0.85rem;
                top: 50%;
                transform: translateY(-50%);
                background: none;
                border: none;
                cursor: pointer;
                color: #6b7280;
                padding: 0;
                display: flex;
                align-items: center;
            }
            .toggle-eye:hover { color: #374151; }

            /* Strength bar */
            .strength-bar-track {
                width: 16rem;
                height: 5px;
                background: #d1fae5;
                border-radius: 9999px;
                overflow: hidden;
            }
            .strength-bar-fill {
                height: 100%;
                border-radius: 9999px;
                transition: width 0.4s ease, background-color 0.4s ease;
                width: 0%;
                background-color: #ef4444;
            }

            /* Fade-in animation */
            @keyframes fadeUp {
                from { opacity: 0; transform: translateY(18px); }
                to   { opacity: 1; transform: translateY(0); }
            }
            .fade-up {
                animation: fadeUp 0.55s ease both;
            }
            .fade-up:nth-child(1) { animation-delay: 0.05s; }
            .fade-up:nth-child(2) { animation-delay: 0.12s; }
            .fade-up:nth-child(3) { animation-delay: 0.19s; }
            .fade-up:nth-child(4) { animation-delay: 0.26s; }
            .fade-up:nth-child(5) { animation-delay: 0.33s; }
            .fade-up:nth-child(6) { animation-delay: 0.40s; }
            .fade-up:nth-child(7) { animation-delay: 0.47s; }
            .fade-up:nth-child(8) { animation-delay: 0.54s; }

            /* Requirement checklist */
            .req-item { transition: color 0.25s ease; }
            .req-item.met { color: #d1fae5; }
            .req-item.unmet { color: #fca5a5; }
        </style>
    </head>
    <body class="flex items-center justify-center h-full relative overflow-hidden">

        <!-- Background Circle (matches login page) -->
        <div class="absolute w-[1000px] h-[1000px] rounded-full bg-green-200/50"></div>

        <!-- Change Password Form -->
        <form id="changePasswordForm" action="/change-password" method="POST"
              class="flex flex-col items-center space-y-4 z-10">

            <!-- Logo -->
            <img src="../Assets/icons/logo.svg" alt="LABubuddy Logo"
                 class="w-48 h-auto fade-up" />

            <!-- Title -->
            <h1 class="logo-title text-white text-4xl fade-up">L A B u b u d d y</h1>

            <!-- Subtitle -->
            <p class="text-white/80 text-sm tracking-wide fade-up">Change Your Password</p>

            <!-- Current Password -->
            <div class="input-wrapper fade-up">
                <input type="password" id="currentPassword" name="currentPassword"
                       placeholder="Current Password" required />
                <button type="button" class="toggle-eye" onclick="toggleVisibility('currentPassword', this)"
                        aria-label="Toggle current password visibility">
                    <svg id="currentPassword-icon" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4"
                         fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7
                                 -1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                    </svg>
                </button>
            </div>

            <!-- New Password -->
            <div class="input-wrapper fade-up">
                <input type="password" id="newPassword" name="newPassword"
                       placeholder="New Password" required
                       oninput="evaluateStrength(this.value)" />
                <button type="button" class="toggle-eye" onclick="toggleVisibility('newPassword', this)"
                        aria-label="Toggle new password visibility">
                    <svg id="newPassword-icon" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4"
                         fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7
                                 -1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                    </svg>
                </button>
            </div>

            <!-- Password Strength Bar -->
            <div class="fade-up flex flex-col items-center space-y-1 w-64">
                <div class="strength-bar-track">
                    <div class="strength-bar-fill" id="strengthBar"></div>
                </div>
                <p class="text-white/70 text-xs self-end" id="strengthLabel"></p>
            </div>

            <!-- Password Requirements -->
            <ul class="text-xs space-y-0.5 self-start ml-[calc(50%-8rem)] fade-up">
                <li class="req-item unmet" id="req-length">✗ At least 8 characters</li>
                <li class="req-item unmet" id="req-upper">✗ One uppercase letter</li>
                <li class="req-item unmet" id="req-number">✗ One number</li>
                <li class="req-item unmet" id="req-special">✗ One special character</li>
            </ul>

            <!-- Confirm New Password -->
            <div class="input-wrapper fade-up">
                <input type="password" id="confirmPassword" name="confirmPassword"
                       placeholder="Confirm New Password" required
                       oninput="checkMatch()" />
                <button type="button" class="toggle-eye" onclick="toggleVisibility('confirmPassword', this)"
                        aria-label="Toggle confirm password visibility">
                    <svg id="confirmPassword-icon" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4"
                         fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7
                                 -1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                    </svg>
                </button>
            </div>
            <p class="text-xs h-3 fade-up" id="matchMsg"></p>

            <!-- Submit -->
            <button type="submit" id="submitBtn"
                    class="w-64 px-4 py-2 rounded-full bg-emerald-700 text-white font-bold outline-none shadow-md
                           flex items-center justify-center transition-transform duration-200
                           hover:scale-105 hover:shadow-lg fade-up
                           disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100">
                Change Password
            </button>

            <!-- Back to login -->
            <p class="text-white text-sm fade-up">
                <a href="/login" class="underline">← Back to Login</a>
            </p>
        </form>

        {{#if error}}
        <script>alert("{{error}}");</script>
        {{/if}}

        {{#if success}}
        <script>alert("Password changed successfully!");</script>
        {{/if}}

        <script>
            /* ── Eye toggle ── */
            const eyeOpen = `<path stroke-linecap="round" stroke-linejoin="round"
                d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round"
                d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7
                   -1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>`;
            const eyeClosed = `<path stroke-linecap="round" stroke-linejoin="round"
                d="M13.875 18.825A10.05 10.05 0 0112 19c-4.477 0-8.268-2.943-9.542-7
                   a9.97 9.97 0 012.128-3.661M6.343 6.343A9.956 9.956 0 0112 5
                   c4.477 0 8.268 2.943 9.542 7a9.97 9.97 0 01-1.337 2.698
                   M6.343 6.343L3 3m3.343 3.343l9.314 9.314M9.88 9.88a3 3 0 104.243 4.243
                   M9.88 9.88L3 3m6.88 6.88l4.242 4.242M21 21l-6.88-6.88"/>`;

            function toggleVisibility(fieldId, btn) {
                const input = document.getElementById(fieldId);
                const icon  = document.getElementById(fieldId + '-icon');
                const show  = input.type === 'password';
                input.type  = show ? 'text' : 'password';
                icon.innerHTML = show ? eyeClosed : eyeOpen;
            }

            /* ── Strength evaluator ── */
            function evaluateStrength(val) {
                const bar   = document.getElementById('strengthBar');
                const label = document.getElementById('strengthLabel');

                const checks = {
                    length:  val.length >= 8,
                    upper:   /[A-Z]/.test(val),
                    number:  /[0-9]/.test(val),
                    special: /[^A-Za-z0-9]/.test(val),
                };

                // Update requirement items
                Object.entries(checks).forEach(([key, met]) => {
                    const el = document.getElementById('req-' + key);
                    el.classList.toggle('met', met);
                    el.classList.toggle('unmet', !met);
                    el.textContent = (met ? '✓ ' : '✗ ') + el.textContent.slice(2);
                });

                const score = Object.values(checks).filter(Boolean).length;
                const levels = [
                    { w: '0%',   color: '#ef4444', text: '' },
                    { w: '25%',  color: '#ef4444', text: 'Weak' },
                    { w: '50%',  color: '#f59e0b', text: 'Fair' },
                    { w: '75%',  color: '#84cc16', text: 'Good' },
                    { w: '100%', color: '#10b981', text: 'Strong' },
                ];
                bar.style.width           = levels[score].w;
                bar.style.backgroundColor = levels[score].color;
                label.textContent         = levels[score].text;
                label.style.color         = levels[score].color;

                checkMatch();
            }

            /* ── Match checker ── */
            function checkMatch() {
                const np  = document.getElementById('newPassword').value;
                const cp  = document.getElementById('confirmPassword').value;
                const msg = document.getElementById('matchMsg');
                const btn = document.getElementById('submitBtn');

                if (!cp) { msg.textContent = ''; return; }

                if (np === cp) {
                    msg.textContent = '✓ Passwords match';
                    msg.style.color = '#d1fae5';
                    btn.disabled    = false;
                } else {
                    msg.textContent = '✗ Passwords do not match';
                    msg.style.color = '#fca5a5';
                    btn.disabled    = true;
                }
            }

            /* ── Form submit guard ── */
            document.getElementById('changePasswordForm').addEventListener('submit', function(e) {
                const np = document.getElementById('newPassword').value;
                const cp = document.getElementById('confirmPassword').value;
                if (np !== cp) {
                    e.preventDefault();
                    alert('Passwords do not match.');
                }
            });
        </script>
    </body>
</html>
