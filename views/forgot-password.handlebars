<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <link href="../CSS/login-style.css" rel="stylesheet">
</head>
<body>
    <div class="container">
        <div class="login-box">
            <h1>Forgot Password</h1>
            {{#if error}}
                <div class="error-message">{{error}}</div>
            {{/if}}
            {{#if success}}
                <div class="success-message">
                    <p>Your password has been reset successfully.</p>
                    <p>You can now log in with your new password.</p>
                    <a href="/login">Back to Login</a>
                </div>
            {{else}}
                <form id="forgotForm" action="/forgot-password" method="POST">
                    {{#unless securityQuestion}}
                        <!-- Step 1: Enter email -->
                        <div class="input-group">
                            <label for="email">Email:</label>
                            <input type="email" id="email" name="email" required>
                        </div>
                        <button type="submit" class="login-btn">Next</button>
                    {{else}}
                        <!-- Step 2: Answer question and set new password -->
                        <input type="hidden" name="email" value="{{user.email}}">
                        <div class="question-group">
                            <p><strong>Security Question:</strong> {{securityQuestion}}</p>
                        </div>
                        <div class="input-group">
                            <label for="securityAnswer">Security Answer:</label>
                            <input type="text" id="securityAnswer" name="securityAnswer" required>
                        </div>
                        <div class="input-group">
                            <label for="newPassword">New Password:</label>
                            <input type="password" id="newPassword" name="newPassword" required minlength="6">
                        </div>
                        <button type="submit" class="login-btn">Reset Password</button>
                    {{/unless}}
                </form>
                <div class="links">
                    <a href="/login">Back to Login</a>
                </div>
            {{/if}}
        </div>
    </div>
</body>
</html>