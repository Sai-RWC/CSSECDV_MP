<!DOCTYPE html>
<title>LABubuddies - Forgot Password</title>

<link href="../CSS/login-style.css" rel="stylesheet">
<link href="../CSS/signup.css" rel="stylesheet">
<script src="https://cdn.tailwindcss.com"></script>

<body class="flex items-center justify-center h-full relative overflow-hidden">

  <!-- Background Circle -->
  <div class="absolute w-[1000px] h-[1000px] rounded-full bg-[#D9F1DD] opacity-20"></div>

  {{#if error}}
  <div class="fixed top-10 left-1/2 transform -translate-x-1/2 bg-red-100 text-red-800 border border-red-400 px-6 py-4 rounded shadow-lg z-50 max-w-md w-full text-center">
    ⚠️ {{error}}
    <button onclick="this.parentElement.remove()" class="mt-2 text-sm underline text-red-600 hover:text-red-800 block mx-auto">
      Close
    </button>
  </div>
  {{/if}}

  {{#if success}}
  <div class="fixed top-10 left-1/2 transform -translate-x-1/2 bg-green-100 text-green-800 border border-green-400 px-6 py-4 rounded shadow-lg z-50 max-w-md w-full text-center">
    ✅ {{success}}
    <button onclick="this.parentElement.remove()" class="mt-2 text-sm underline text-green-600 hover:text-green-800 block mx-auto">
      Close
    </button>
  </div>
  {{/if}}

  <!-- Forgot Password Form -->
  <form action="/forgot-password" method="POST"
    class="flex flex-col items-center space-y-4 z-10 w-full max-w-md">

    <img src="../Assets/icons/logo.svg" alt="LABubuddy Logo" class="w-48 h-auto" />
    <h1 class="logo-title text-white text-4xl">Forgot Password</h1>

    <!-- Email / Username -->
    <input type="email" name="email" placeholder="Email"
      class="w-64 px-4 py-2 rounded-full outline-none shadow-lg"
      required />

    <!-- Security Question -->
    <label class="text-white text-sm font-semibold">Password Reset Question</label>

    <select name="securityQuestion"
      class="w-64 px-4 py-2 rounded-full outline-none shadow-lg"
      required>

      <option value="" disabled selected>Select your security question</option>

      <option value="school_id_format">What was the exact format of your first school ID number (e.g., YYYY-XXXX, YY-DEP-XXXX)?</option>
      <option value="pet_registered_name">What was the official registered name of your first pet as written in veterinary records?</option>
      <option value="first_phone_model">What was the exact model number of your first mobile phone?</option>
      <option value="first_pc_model">What was the full model designation of your first personal computer or laptop?</option>
      <option value="first_username">What was your first username that is still recoverable?</option>
      <option value="childhood_street">What was the exact street name of your childhood home address?</option>
      <option value="router_model">What was the model number of your first home router?</option>
      <option value="first_device_model">What was the model number of your first personal electronic device?</option>
      <option value="first_community">What was the first forum or online community you joined for more than one month?</option>
      <option value="first_school_org">What was the first school organization or club you joined?</option>

    </select>

    <!-- Security Answer -->
    <input type="text" name="securityAnswer" placeholder="Answer"
      class="w-64 px-4 py-2 rounded-full outline-none shadow-lg"
      required />

    <button type="submit"
      class="w-64 px-4 py-2 rounded-full bg-emerald-700 text-white font-bold shadow-lg transition-all hover:scale-105 hover:shadow-lg">
      Password Reset
    </button>

    <p class="text-white text-sm">
      Back to <a href="/login" class="underline">Login</a>
    </p>

  </form>

</body>