<script src="https://cdn.tailwindcss.com"></script>
<script src="/JS/viewprofile.js"></script>

<body class="bg-gradient-to-br from-green-400 to-green-600 min-h-screen">
    <main class="p-4 md:p-6 max-w-4xl mx-auto">
        <div class="rounded-3xl shadow-lg p-8 mx-4" style="background: linear-gradient(135deg, #a8e6cf 0%, #dcedc1 100%);">
            {{#if view}}
            <div class="mb-8">
                <div class="flex justify-center mb-6">
                    <div class="w-32 h-32 rounded-full overflow-hidden border-4 border-white shadow-lg">
                        <img id="profile-image"
                             src="{{#if view.profPic}}{{view.profPic}}{{else}}/Assets/images/default-avatar.png{{/if}}"
                             alt="Profile Picture"
                             class="w-full h-full object-cover">
                    </div>
                </div>

                <h1 class="text-3xl font-bold text-gray-800 text-center mb-2">{{view.fName}} {{view.lName}}</h1>

                <!-- Role badge -->
                <div class="flex justify-center mb-8">
                    <span class="px-4 py-1 rounded-full text-2xl font-semibold
                        {{#if (eq view.role 'admin')}}bg-purple-100 text-purple-700
                        {{else if (eq view.role 'technician')}}bg-blue-100 text-blue-700
                        {{else}}bg-green-100 text-green-700{{/if}}">
                        {{view.role}}
                    </span>
                </div>

                <!-- Description -->
                <div class="mb-8">
                    <p class="text-3xl font-semibold text-gray-700 mb-3">Description</p>
                    <div class="rounded-2xl p-4 border border-white/30" style="background: rgba(255, 255, 255, 0.4);">
                        <p class="text-gray-700">{{view.profDesc}}</p>
                    </div>

                    {{#if isOwnProfile}}
                    <div class="flex flex-col items-center gap-3 mt-4">
                        <button onclick="window.location.href='/editprofile'"
                                class="px-6 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors font-semibold">
                            Edit Profile
                        </button>
                        <button onclick="confirmDeleteAccount()" data-user-id="{{view.idNum}}"
                                class="px-6 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors font-semibold">
                            Delete Account
                        </button>
                    </div>
                    {{/if}}
                </div>

                <!-- Admin: Change Role -->
                {{#if isAdmin}}
                {{#unless isOwnProfile}}
                <div class="rounded-2xl p-5 border border-white/30 mb-6" style="background: rgba(255, 255, 255, 0.4);">
                    <p class="text-3xl font-semibold text-gray-700 mb-3">Change Role</p>
                    <form id="roleForm" action="/admin/change-role" method="POST" class="flex items-center gap-3">
                        <input type="hidden" name="userId" value="{{view._id}}">
                        <select name="role" id="roleSelect"
                                class="flex-1 px-4 py-2 rounded-lg border border-white/50 bg-white/70 text-gray-800 font-medium focus:outline-none focus:ring-2 focus:ring-green-400">
                            <option value="user"    {{#if (eq view.role 'user')}}selected{{/if}}>Student</option>
                            <option value="moderator" {{#if (eq view.role 'moderator')}}selected{{/if}}>Moderator</option>
                            <option value="admin"      {{#if (eq view.role 'admin')}}selected{{/if}}>Admin</option>
                        </select>
                        <button type="submit"
                                class="px-5 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors font-semibold whitespace-nowrap">
                            Save Role
                        </button>
                    </form>
                </div>
                {{/unless}}
                {{/if}}

            </div>
            {{/if}}

            {{#unless view.isTech}}
            <div class="pt-8">
                <h2 class="text-2xl font-bold text-gray-800 mb-6">Current Reservations</h2>
                <div class="space-y-4">
                    {{#each reservations}}
                    <div class="rounded-2xl p-4 border border-white/30" style="background: rgba(255, 255, 255, 0.4);">
                        <p class="text-lg font-semibold text-gray-800 mb-1">{{this.slotName}} • {{formatDate this.reqMade}}</p>
                        <p class="text-gray-600">{{this.startTimeLabel}} - {{this.endTimeLabel}}</p>
                    </div>
                    {{/each}}
                    {{#unless reservations.length}}
                    <p class="text-center text-gray-600">No reservations found.</p>
                    {{/unless}}
                </div>
            </div>
            {{/unless}}
        </div>
    </main>
</body>
